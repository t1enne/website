---
import type { ResumeI18n } from "../i18n/types";
import BaseHead from "./BaseHead.astro";
import IconButton from "./IconButton.astro";
import WorkExperienceItem from "./WorkExperienceItem.astro";
import EducationItem from "./EducationItem.astro";
import CourseItem from "./CourseItem.astro";
import ProjectItem from "./ProjectItem.astro";
import LanguageItem from "./LanguageItem.astro";
import SkillsSection from "./SkillsSection.astro";
import ResumeJsonLd from "./ResumeJsonLd.astro";
import { Languages, Linkedin, Phone, Mail, Printer, FileText, Github } from "lucide-astro";
import { SITE_TITLE, SITE_DESCRIPTION } from "../consts";

interface Props {
  lang: "en" | "it" | "fr";
  i18n: ResumeI18n;
}

const { lang, i18n } = Astro.props;
const t = i18n.labels;

const jobTitle = "Full Stack Developer";
const email = "nasir.taov@gmail.com";
const phone = "+39 328 1934728";
const linkedinUrl = "https://www.linkedin.com/in/nasir-taov";

const contactItems = [
  { href: `mailto:${email}`, icon: Mail, label: `mail: ${email}` },
  { href: `tel:${phone.replace(/\s/g, "")}`, icon: Phone, label: `phone: ${phone}` },
];
---

<!DOCTYPE html>
<html lang={lang}>
  <head>
    <BaseHead title={`${SITE_TITLE} - Resume`} description={SITE_DESCRIPTION} />
    <ResumeJsonLd
      name="Nasir Taov"
      jobTitle={jobTitle}
      email={email}
      phone={phone}
      linkedin={linkedinUrl}
      skills={i18n.allSkills}
      languages={i18n.languages}
    />
  </head>
  <body class="print:bg-white">
    <main
      class="p-6 max-w-3xl mx-auto my-8 text-base bg-white print:p-8 print:my-0"
      itemscope
      itemtype="https://schema.org/Person"
    >
      <meta itemprop="name" content="Nasir Taov" />
      <meta itemprop="jobTitle" content={jobTitle} />
      <meta itemprop="email" content={email} />
      <meta itemprop="telephone" content={phone} />

      <!-- Header -->
      <div class="flex items-center justify-between print:mb-2">
        <div class="pr-4">
          <h1 class="font-bold text-3xl print:text-2xl print:mb-0">Nasir Taov</h1>
          <span class="text-sm text-muted font-medium block print:text-base print:text-black">{jobTitle}</span>
          <div class="py-2 hidden print:block" />
          <div class="flex items-center gap-2 print:hidden mt-2">
            {contactItems.map((item) => (
              <IconButton href={item.href}><item.icon size={18} /></IconButton>
            ))}
            <IconButton href={linkedinUrl} target="_blank"><Linkedin size={18} /></IconButton>
            <IconButton href="https://github.com/t1enne" target="_blank" title="GitHub"
              ><Github size={18} /></IconButton
            >
            <IconButton onclick="window.print()" title="Press to print"
              ><Printer size={18} /></IconButton
            >
						<IconButton href={`/resume-${lang}.pdf`} title="Download PDF"
              ><FileText size={18} /></IconButton
            >
          </div>
          <!-- Print contact info -->
          <div class="hidden print:block print:mt-1">
            <p class="text-xs text-muted">{t.contactLocation}: {t.location} &nbsp;|&nbsp; {t.contactEmail}: {email} &nbsp;|&nbsp; {t.contactPhone}: {phone}</p>
            <p class="text-xs text-muted">{t.contactLinkedin}: linkedin.com/in/nasir-taov &nbsp;|&nbsp; {t.contactGithub}: github.com/t1enne &nbsp;|&nbsp; {t.citizenshipLabel}: {t.citizenship}</p>
          </div>
        </div>
        <div class="overflow-hidden rounded-lg print:hidden">
          <img
            class="max-w-none w-20 h-20 sm:w-24 sm:h-24 md:w-28 md:h-28"
            src="../self_2.jpeg"
            alt="Nasir Taov"
            itemprop="image"
          />
        </div>
      </div>

      <!-- Lang switcher (hidden print) -->
      <div class="flex items-center print:hidden mt-2">
        <Languages size={12} />
        <ul class="flex divide-x text-sm text-muted ml-1">
          <li><a class="p-2" href="/en/">EN</a></li>
          <li><a class="p-2" href="/it/">IT</a></li>
          <li><a class="p-2" href="/fr/">FR</a></li>
        </ul>
      </div>

			<div class="mb-6"></div>

      <!-- Summary -->
      <section aria-labelledby="about-heading" class="mb-6">
        <h2 id="about-heading" class="font-bold text-2xl print:text-lg mb-3">{t.aboutTitle}</h2>
        <p class="text-muted text-sm leading-relaxed" itemprop="description">
          {t.aboutContent}
        </p>
      </section>

      <!-- Work Experience -->
      <section aria-labelledby="work-heading" class="mb-6">
        <h2 id="work-heading" class="font-bold text-2xl print:text-lg mb-3">{t.workTitle}</h2>
        <ul class="w-full">
          {i18n.workExperience.map((exp) => (
            <WorkExperienceItem
              title={exp.title}
              company={exp.company}
              location={exp.location}
              dates={exp.dates}
              description={exp.description}
              tags={exp.tags}
            />
          ))}
        </ul>
      </section>

      <!-- Projects -->
      <section aria-labelledby="projects-heading" class="mb-6">
        <h2 id="projects-heading" class="font-bold text-2xl print:text-lg mb-3">{t.projectsTitle}</h2>
        <ul class="w-full space-y-2">
          {i18n.projects.map((proj) => (
            <ProjectItem
              title={proj.title}
              period={proj.period}
              technologies={proj.technologies}
              description={proj.description}
              url={proj.url}
              closedSource={proj.closedSource}
            />
          ))}
        </ul>
      </section>

      <!-- Skills -->
      <section aria-labelledby="skills-heading" class="mb-6">
        <SkillsSection categories={i18n.skills} title={t.skillsTitle} />
      </section>

      <!-- Education -->
      <section aria-labelledby="education-heading" class="mb-6 print:mb-2">
        <h2 id="education-heading" class="font-bold text-2xl mb-3 print:text-lg">{t.educationTitle}</h2>
        <ul class="w-full">
          {i18n.education.map((edu) => (
            <EducationItem
              title={edu.title}
              location={edu.location}
              dates={edu.dates}
              score={edu.score}
            />
          ))}
        </ul>
      </section>

      <!-- Courses -->
      <section aria-labelledby="courses-heading" class="mb-6">
        <h2 id="courses-heading" class="font-bold text-2xl print:text-lg mb-3">{t.coursesTitle}</h2>
        <ul class="w-full space-y-2">
          {i18n.courses.map((course) => (
            <CourseItem title={course.title} provider={course.provider} dates={course.dates} summary={course.summary} />
          ))}
        </ul>
      </section>

      <!-- Languages -->
      <section aria-labelledby="languages-heading" class="mb-6">
        <h2 id="languages-heading" class="font-bold text-2xl print:text-lg mb-3">{t.langsTitle}</h2>
        <ul class="w-full divide-y divide-gray-100" itemprop="knowsLanguage">
          {i18n.languages.map((langEntry) => (
            <LanguageItem name={langEntry.name} level={langEntry.level} />
          ))}
        </ul>
      </section>
    </main>
  </body>
</html>
