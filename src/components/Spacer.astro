---
interface Props {
  size?: 'xs' | 'sm' | 'md' | 'lg' | number;
}

const { size = 'md' } = Astro.props;

const sizeClasses: Record<string, string> = {
  xs: 'py-0.5',
  sm: 'py-2 print:py-1',
  md: 'py-4 print:py-2',
  lg: 'py-8 print:py-3',
};

const sizeClass = typeof size === 'number' 
  ? `py-[${size}px]` 
  : sizeClasses[size];
---

<div class={`${sizeClass}`} />
