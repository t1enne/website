---
import Tag from './Tag.astro';

interface Props {
  title: string;
  company: string;
  location: string;
  dates: string;
  description: string;
  tags?: string[];
}

const { title, company, location, dates, description, tags = [] } = Astro.props;

// Split description into bullet points
const bullets = description.trim().split('\n').filter(line => line.trim());
---

<li class="mb-6" itemscope itemtype="https://schema.org/OrganizationRole">
  <div class="flex flex-col sm:flex-row sm:justify-between sm:items-baseline gap-0.5">
    <h3 class="font-bold text-lg" itemprop="roleName">{title}</h3>
    <time class="text-muted font-mono text-sm">{dates}</time>
  </div>
  <h4 class="text-sm text-muted mb-1">
    <span itemprop="name">{company}</span> — {location}
  </h4>
  <!-- Tag chips (screen only) -->
  <div class="print:hidden flex flex-wrap gap-1 my-2">
    {tags.map(tag => <Tag text={tag} />)}
  </div>
	<div class="py-2" />
  <!-- Bullets -->
  <ul class="list-disc list-outside ml-4 space-y-2">
    {bullets.map(bullet => (
      <li class="font-mono text-muted text-xs leading-relaxed">
        {bullet.replace(/^[-•]\s*/, '').trim()}
      </li>
    ))}
  </ul>
</li>
